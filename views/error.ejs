<div class="row justify-content-center align-items-center text-center" style="min-height: 60vh;">
  <div class="col-md-8 col-lg-6">
    <div class="mb-4">
      <i class="fa-solid fa-triangle-exclamation text-danger" style="font-size: 6rem; opacity: 0.8;"></i>
    </div>
    <h1 class="display-3 fw-bold text-dark mb-3">¡Ups!</h1>
    <h3 class="text-muted mb-5"><%= message %></h3>
    
    <% if (error && error.stack) { %>
      <div class="text-start bg-dark text-light p-4 rounded-4 shadow-sm overflow-auto mb-5" style="max-height: 300px; font-size: 0.9rem;">
        <pre class="mb-0"><code><%= error.stack %></code></pre>
      </div>
    <% } %>
    
    <a href="/" class="btn btn-custom-primary btn-lg px-5 rounded-pill shadow-sm">
      <i class="fa-solid fa-home me-2"></i> Volver al Inicio
    </a>
  </div>
</div>