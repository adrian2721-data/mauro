<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
  <div class="col-md-6 col-lg-5">
    <div class="card auth-card">
      <div class="auth-header">
        <div class="mb-3">
          <i class="fa-solid fa-user-circle" style="font-size: 4rem; opacity: 0.9;"></i>
        </div>
        <h2>¡Bienvenido de vuelta!</h2>
        <p class="mb-0 mt-2" style="color: rgba(255,255,255,0.8);">Inicia sesión para compartir tus recetas.</p>
      </div>
      <div class="card-body p-5">
        
        <% if (error) { %>
          <div class="alert alert-danger border-0 shadow-sm rounded-3 d-flex align-items-center mb-4">
            <i class="fa-solid fa-circle-exclamation me-3 fs-5"></i>
            <div><%= error %></div>
          </div>
        <% } %>

        <form action="/auth/login" method="POST">
          <div class="mb-4">
            <label for="email" class="form-label text-muted"><i class="fa-solid fa-envelope me-2"></i>Correo Electrónico</label>
            <input type="email" class="form-control custom-form-control py-3" id="email" name="email" placeholder="tu@email.com" required>
          </div>
          <div class="mb-5">
            <label for="password" class="form-label text-muted"><i class="fa-solid fa-lock me-2"></i>Contraseña</label>
            <input type="password" class="form-control custom-form-control py-3" id="password" name="password" placeholder="••••••••" required>
          </div>
          <button type="submit" class="btn btn-custom-primary w-100 py-3 fs-5 mb-4 shadow-lg">
            Iniciar Sesión <i class="fa-solid fa-arrow-right ms-2"></i>
          </button>
        </form>
        
        <div class="text-center mt-2 border-top pt-4">
          <p class="text-muted mb-0">¿No tienes cuenta? <a href="/auth/register" class="text-decoration-none fw-bold" style="color: var(--secondary-color);">Regístrate aquí</a></p>
        </div>
      </div>
    </div>
  </div>
</div>