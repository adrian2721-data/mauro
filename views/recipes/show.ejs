<div class="row">
  <div class="col-lg-10 mx-auto">
    <nav aria-label="breadcrumb" class="mb-4">
      <ol class="breadcrumb bg-white p-3 rounded-pill shadow-sm">
        <li class="breadcrumb-item"><a href="/recipes" class="text-decoration-none text-muted"><i class="fa-solid fa-home me-1"></i>Inicio</a></li>
        <li class="breadcrumb-item"><a href="/recipes" class="text-decoration-none text-muted">Recetas</a></li>
        <li class="breadcrumb-item active fw-bold" aria-current="page" style="color: var(--primary-color);"><%= recipe.title %></li>
      </ol>
    </nav>

    <div class="recipe-hero mb-5">
      <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
          <span class="badge bg-light text-dark mb-3 px-3 py-2 rounded-pill shadow-sm border">
            <i class="fa-solid fa-tag text-primary me-1"></i> <%= recipe.category %>
          </span>
          <h1 class="display-4 fw-bold mb-3" style="color: var(--text-dark); letter-spacing: -1px;"><%= recipe.title %></h1>
          
          <div class="d-flex align-items-center gap-4 text-muted">
            <div>
              <i class="fa-solid fa-user-circle text-primary fs-5 me-2"></i>
              <strong><%= recipe.author.name %></strong>
            </div>
            <div>
              <i class="fa-regular fa-calendar text-secondary fs-5 me-2"></i>
              <%= new Date(recipe.createdAt).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' }) %>
            </div>
          </div>
        </div>
        
        <% if (user && (user._id.toString() === recipe.author._id.toString() || user.role === 'admin')) { %>
          <div class="dropdown">
            <button class="btn btn-light rounded-circle shadow-sm p-3 border-0" type="button" data-bs-toggle="dropdown" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
              <i class="fa-solid fa-ellipsis-vertical fs-5 text-muted"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-2">
              <li><a class="dropdown-item py-2" href="/recipes/<%= recipe._id %>/edit"><i class="fa-solid fa-pen me-2 text-secondary"></i> Editar Receta</a></li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <form action="/recipes/<%= recipe._id %>?_method=DELETE" method="POST" onsubmit="return confirm('¿Estás seguro de eliminar esta receta? Esta acción no se puede deshacer.');">
                  <button type="submit" class="dropdown-item py-2 text-danger fw-bold"><i class="fa-solid fa-trash me-2"></i> Eliminar</button>
                </form>
              </li>
            </ul>
          </div>
        <% } %>
      </div>

      <% if (recipe.image) { %>
        <div class="mb-4 text-center">
          <img src="<%= recipe.image %>" alt="<%= recipe.title %>" class="img-fluid rounded-4 shadow-sm" style="max-height: 400px; width: 100%; object-fit: cover;">
        </div>
      <% } %>

      <p class="lead text-muted mb-0" style="line-height: 1.8; font-size: 1.2rem;"><%= recipe.description %></p>
    </div>

    <div class="row g-5 mb-5">
      <div class="col-md-4">
        <div class="bg-white p-4 rounded-4 shadow-sm border-0 h-100">
          <h4 class="fw-bold mb-4 d-flex align-items-center" style="color: var(--primary-color);">
            <i class="fa-solid fa-basket-shopping me-3 fs-3"></i> Ingredientes
          </h4>
          <div class="mt-4">
            <% recipe.ingredients.forEach(ingredient => { %>
              <div class="ingredient-item">
                <i class="fa-solid fa-check text-secondary me-2"></i>
                <%= ingredient %>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
      
      <div class="col-md-8">
        <div class="h-100">
          <h4 class="fw-bold mb-4 d-flex align-items-center" style="color: var(--secondary-color);">
            <i class="fa-solid fa-list-check me-3 fs-3"></i> Instrucciones
          </h4>
          <div class="instruction-box">
            <%= recipe.instructions %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>