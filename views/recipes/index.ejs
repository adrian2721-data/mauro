<div class="d-flex justify-content-between align-items-center mb-5">
  <div>
    <h1 class="fw-bold mb-1" style="color: var(--primary-color);">Descubre Recetas</h1>
    <p class="text-muted fs-5">Encuentra tu próximo plato favorito preparado por nuestra comunidad.</p>
  </div>
  <% if (user) { %>
    <a href="/recipes/new" class="btn btn-custom-primary d-none d-md-inline-block">
      <i class="fa-solid fa-plus me-1"></i> Crear Receta
    </a>
  <% } %>
</div>

<!-- Búsqueda y Filtros -->
<div class="card search-card">
  <div class="card-body p-4">
    <form action="/recipes" method="GET" class="row g-3 align-items-center">
      <div class="col-md-4">
        <div class="input-group">
          <span class="input-group-text bg-transparent border-0 position-absolute" style="z-index: 10; margin-top: 2px;">
            <i class="fa-solid fa-search text-muted"></i>
          </span>
          <input type="text" name="search" class="form-control search-input ps-5" placeholder="Buscar receta..." value="<%= search %>">
        </div>
      </div>
      <div class="col-md-3">
        <select name="category" class="form-select filter-select">
          <option value="">✨ Todas las categorías</option>
          <option value="Desayuno" <%= category === 'Desayuno' ? 'selected' : '' %>>🌅 Desayuno</option>
          <option value="Almuerzo" <%= category === 'Almuerzo' ? 'selected' : '' %>>🌞 Almuerzo</option>
          <option value="Cena" <%= category === 'Cena' ? 'selected' : '' %>>🌙 Cena</option>
          <option value="Postre" <%= category === 'Postre' ? 'selected' : '' %>>🍰 Postre</option>
          <option value="Bebida" <%= category === 'Bebida' ? 'selected' : '' %>>🍹 Bebida</option>
          <option value="Otro" <%= category === 'Otro' ? 'selected' : '' %>>🍽️ Otro</option>
        </select>
      </div>
      <div class="col-md-2">
        <select name="limit" class="form-select filter-select">
          <option value="6" <%= limit === 6 ? 'selected' : '' %>>6 items</option>
          <option value="12" <%= limit === 12 ? 'selected' : '' %>>12 items</option>
          <option value="24" <%= limit === 24 ? 'selected' : '' %>>24 items</option>
        </select>
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-custom-secondary w-100">
          <i class="fa-solid fa-filter me-1"></i> Filtrar
        </button>
      </div>
    </form>
  </div>
</div>

<% if (user) { %>
  <div class="d-md-none mb-4 text-center">
    <a href="/recipes/new" class="btn btn-custom-primary w-100">
      <i class="fa-solid fa-plus me-1"></i> Crear Receta
    </a>
  </div>
<% } %>

<!-- Listado de Recetas -->
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
  <% if (recipes.length === 0) { %>
    <div class="col-12 text-center py-5">
      <div class="mb-4">
        <i class="fa-solid fa-folder-open text-muted" style="font-size: 4rem; opacity: 0.3;"></i>
      </div>
      <h3 class="text-muted fw-bold">No se encontraron recetas</h3>
      <p class="text-muted">Intenta con otros términos de búsqueda o categorías.</p>
    </div>
  <% } %>

  <% recipes.forEach(recipe => { %>
    <div class="col">
      <div class="recipe-card">
        <% if (recipe.image) { %>
          <div class="recipe-header" style="background: url('<%= recipe.image %>') center/cover; position: relative;">
            <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.1), rgba(0,0,0,0.4));"></div>
        <% } else { %>
          <div class="recipe-header <%= recipe.category %>">
        <% } %>
          <span class="category-badge">
            <% if(recipe.category === 'Desayuno') { %>🌅<% } %>
            <% if(recipe.category === 'Almuerzo') { %>🌞<% } %>
            <% if(recipe.category === 'Cena') { %>🌙<% } %>
            <% if(recipe.category === 'Postre') { %>🍰<% } %>
            <% if(recipe.category === 'Bebida') { %>🍹<% } %>
            <% if(recipe.category === 'Otro') { %>🍽️<% } %>
            <%= recipe.category %>
          </span>
        </div>
        <div class="recipe-body">
          <h5 class="recipe-title"><%= recipe.title %></h5>
          <p class="recipe-desc text-truncate" style="-webkit-line-clamp: 2; -webkit-box-orient: vertical; display: -webkit-box; white-space: normal;"><%= recipe.description %></p>
          <div class="recipe-meta mb-4">
            <i class="fa-solid fa-user-circle"></i> <%= recipe.author.name %>
          </div>
          <div class="d-flex gap-2 mt-auto">
            <a href="/recipes/<%= recipe._id %>" class="btn btn-custom-outline flex-grow-1 text-center">
              Ver Receta <i class="fa-solid fa-arrow-right ms-1"></i>
            </a>
            <% if (user && (user._id.toString() === recipe.author._id.toString() || user.role === 'admin')) { %>
              <a href="/recipes/<%= recipe._id %>/edit" class="btn btn-light border text-muted px-3" data-bs-toggle="tooltip" title="Editar">
                <i class="fa-solid fa-pen"></i>
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<!-- Paginación -->
<% if (pages > 1) { %>
  <nav aria-label="Navegación de páginas">
    <ul class="pagination justify-content-center gap-2">
      <% if (page > 1) { %>
        <li class="page-item">
          <a class="page-link border-0 rounded-circle shadow-sm" href="/recipes?page=<%= page - 1 %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
            <i class="fa-solid fa-chevron-left"></i>
          </a>
        </li>
      <% } %>
      
      <% for (let i = 1; i <= pages; i++) { %>
        <li class="page-item">
          <a class="page-link border-0 rounded-circle shadow-sm <%= page === i ? 'bg-primary text-white' : 'text-dark' %>" 
             style="<%= page === i ? 'background-color: var(--primary-color) !important;' : '' %>"
             href="/recipes?page=<%= i %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
             <%= i %>
          </a>
        </li>
      <% } %>
      
      <% if (page < pages) { %>
        <li class="page-item">
          <a class="page-link border-0 rounded-circle shadow-sm" href="/recipes?page=<%= page + 1 %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
            <i class="fa-solid fa-chevron-right"></i>
          </a>
        </li>
      <% } %>
    </ul>
  </nav>
<% } %>